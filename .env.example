# ============================================================
# Exemplo de configuração — copie para .env e preencha
# ============================================================

# Fonte dos dados
DATA_RESOUCES = "https://www.gov.br/cgu/pt-br/acesso-a-informacao/dados-abertos/arquivos/terceirizados"
DATA_METADATA = "https://www.gov.br/cgu/pt-br/acesso-a-informacao/dados-abertos/arquivos/terceirizados/arquivos/descricao-e-dicionario-de-dados.pdf"

# Configurações do Object Storage (MinIO local ou AWS S3)
# Para MinIO local: http://localhost:9000
# Para AWS S3: deixar vazio ou remover a variável
S3_ENDPOINT_URL=http://localhost:9000

# Credenciais de acesso
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
